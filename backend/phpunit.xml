<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="vendor/autoload.php"
         colors="true"
>
    <testsuites>
        <testsuite name="Unit">
            <directory>tests/Unit</directory>
        </testsuite>
        <testsuite name="Feature">
            <directory>tests/Feature</directory>
        </testsuite>
    </testsuites>
    <source>
        <include>
            <directory>app</directory>
        </include>
        <exclude>
            <!-- Framework boilerplate — no business logic to unit-test -->
            <directory>app/Console</directory>
            <directory>app/Exports</directory>
            <directory>app/Http/Middleware</directory>
            <directory>app/Providers</directory>
            <directory>app/Traits</directory>
            <!-- Controllers dependent on external services (IoT) -->
            <file>app/Http/Controllers/Api/CompanyController.php</file>
            <!-- External service implementations — no CI API keys available -->
            <file>app/Services/AI/AIServiceInterface.php</file>
            <file>app/Services/AI/GeminiAIService.php</file>
            <file>app/Services/AI/MistralAIService.php</file>
            <file>app/Services/ThingsBoardService.php</file>
            <!-- Models with no business logic (pure Eloquent boilerplate) -->
            <file>app/Models/ActivityLog.php</file>
            <file>app/Models/IotDevice.php</file>
        </exclude>
    </source>
    <php>
        <env name="APP_ENV" value="testing"/>
        <env name="APP_MAINTENANCE_DRIVER" value="file"/>
        <env name="BCRYPT_ROUNDS" value="4"/>
        <env name="BROADCAST_CONNECTION" value="null"/>
        <env name="CACHE_STORE" value="array"/>
        <env name="DB_CONNECTION" value="sqlite"/>
        <env name="DB_DATABASE" value=":memory:"/>
        <env name="MAIL_MAILER" value="array"/>
        <env name="QUEUE_CONNECTION" value="sync"/>
        <env name="SESSION_DRIVER" value="array"/>
        <env name="PULSE_ENABLED" value="false"/>
        <env name="TELESCOPE_ENABLED" value="false"/>
        <env name="NIGHTWATCH_ENABLED" value="false"/>
        <env name="INTERNAL_API_SECRET" value="test-secret-ci"/>
    </php>
</phpunit>
